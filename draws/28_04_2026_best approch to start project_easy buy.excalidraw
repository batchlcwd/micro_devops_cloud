      "isDeleted": true,
      "boundElements": [],
      "updated": 1777390169675,
      "link": null,
      "locked": false,
      "text": "A monolithic app is a single, unified codebase\nwhere all features are tightly connected and\ndeployed together.",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A monolithic app is a single, unified codebase where all features are tightly connected and deployed together.",
      "autoResize": false,
      "lineHeight": 1.25
    },
