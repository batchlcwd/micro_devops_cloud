      "link": null,
      "locked": false,
      "text": "You have a monolithic Spring Boot application handling users, orders, and\npayments.\n It’s growing fast and facing scaling issues.\n\nWould you migrate to microservices? Why or why not?",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "You have a monolithic Spring Boot application handling users, orders, and payments.\n It’s growing fast and facing scaling issues.\n\nWould you migrate to microservices? Why or why not?",
      "autoResize": false,
      "lineHeight": 1.25
    },
